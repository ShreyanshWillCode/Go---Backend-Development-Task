# ── Server ─────────────────────────────────────────────────────────────────────
# The TCP port the API listens on.
PORT=3000

# ── Database ────────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string. Replace the placeholders with your values.
# Format: postgres://<user>:<password>@<host>:<port>/<database>?sslmode=disable
DATABASE_URL=postgres://postgres:anyx_secret_2024@localhost:5432/anyx_db?sslmode=disable

# ── Environment ─────────────────────────────────────────────────────────────────
# "development" → colorized console logs, debug level
# "production"  → JSON logs, info level
ENVIRONMENT=development
